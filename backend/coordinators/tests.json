{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get available coordinators (no auth)",
      "method": "GET",
      "path": "/?action=available",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "GET",
      "path": "/?action=unknown_action",
      "expectedStatus": 400,
      "expectedBody": {"error": "Неизвестное действие"},
      "bodyMatcher": "partial"
    }
  ]
}
